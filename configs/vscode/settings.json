{
  "window.autoDetectColorScheme": true,
  "window.title": "${activeEditorShort}",
  "window.commandCenter": false,
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "symbols",
  "editor.fontWeight": "400",
  "editor.fontLigatures": true,
  "editor.lineHeight": 24,
  "editor.padding.top": 16,
  "editor.codeLensFontSize": 13,
  "editor.fontFamily": "JetBrains Mono",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "terminal.integrated.sendKeybindingsToShell": true,
  "auto-rename-tag.activationOnLanguage": ["*"],
  "prettier.tabWidth": 2,
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
    "vue-html": "html",
  },
  "editor.linkedEditing": true,
  "editor.tabSize": 2,
  "js/ts.suggest.completeFunctionCalls": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "git.enableSmartCommit": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust",
    "editor.formatOnSave": true,
  },
  "reactSnippets.settings.prettierEnabled": true,
  "git.autofetch": true,
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.startupEditor": "none",
  "editor.snippetSuggestions": "top",
  "editor.tabCompletion": "on",
  "files.autoSave": "onFocusChange",
  "git.openRepositoryInParentFolders": "never",
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.rulers": [80],
    "editor.selectionHighlight": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off",
  },
  "redhat.telemetry.enabled": false,
  "prettier.singleQuote": true,
  "diffEditor.renderSideBySide": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "editor.fontSize": 12,
  "terminal.integrated.defaultProfile.windows": "Git Bash",

  "[blade]": {
    "editor.defaultFormatter": "shufo.vscode-blade-formatter",
  },
  "[php]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
  },

  "laravel-pint.enable": true,
  "laravel-pint.runOnSave": true,
  "symbols.hidesExplorerArrows": false,
  "terminal.integrated.fontFamily": "monospace",
  "easy-codesnap.backgroundColor": "#abb8c3",
  "easy-codesnap.boxShadow": "rgba(0, 0, 0, 0.55) 0px 20px 68px",
  "easy-codesnap.containerPadding": "3em",
  "easy-codesnap.realLineNumbers": false,
  "easy-codesnap.roundedCorners": true,
  "easy-codesnap.showLineNumbers": true,
  "easy-codesnap.showWindowControls": true,
  "easy-codesnap.showWindowTitle": false,
  "easy-codesnap.shutterAction": "copy",
  "easy-codesnap.target": "container",
  "easy-codesnap.transparentBackground": false,
  "easy-codesnap.uiCustomColors": {
    "watermarkPositionInputSelectedBackgroud": "var(--vscode-focusBorder)",
  },
  "workbench.preferredDarkColorTheme": "Tokyo Night Storm",
  "chat.instructionsFilesLocations": {
    ".github/instructions": true,
    ".claude/rules": true,
  },
  "postman.mcp.notifications.postmanMCP": false,
  "dart.mcpServer": true,
  "dart.debugExternalPackageLibraries": false,
  "dart.debugSdkLibraries": false,
  "git.confirmSync": false,
  "chat.editing.confirmEditRequestRemoval": false,
  "chat.mcp.gallery.enabled": true,
  "chat.viewSessions.orientation": "stacked",
  "claudeCode.useTerminal": true,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "editor.minimap.enabled": true,
  "breadcrumbs.enabled": false,
}
